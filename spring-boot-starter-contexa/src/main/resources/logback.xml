<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="CONSOLE_LOG_CHARSET" value="UTF-8"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <charset>UTF-8</charset>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Contexa 패키지 로깅 레벨 -->
    <logger name="io.contexa" level="DEBUG"/>
    <logger name="io.contexa.contexacore.autonomous" level="DEBUG"/>
    <logger name="io.contexa.contexaidentity.security.statemachine" level="DEBUG"/>

    <!-- Spring Framework 로깅 레벨 -->
    <logger name="org.springframework.statemachine" level="DEBUG"/>
    <logger name="org.springframework.security" level="INFO"/>

    <!-- Hibernate SQL 로깅 -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>
</configuration>
